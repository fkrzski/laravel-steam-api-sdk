{
    "name": "fkrzski/laravel-steam-api-sdk",
    "description": "Laravel bridge for fkrzski/php-steam-api-sdk — service provider, Steam facade and test fakes for the Steam Web API.",
    "keywords": ["php", "laravel", "steam", "steam-api", "saloon", "sdk"],
    "license": "MIT",
    "authors": [
        {
            "name": "Filip Krzyżanowski",
            "email": "contact@fkrzski.dev"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "fkrzski/php-steam-api-sdk": "^0.2",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29.1",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.0",
        "rector/rector": "^2.4.2",
        "symfony/var-dumper": "^8.0.8"
    },
    "autoload": {
        "psr-4": {
            "Fkrzski\\LaravelSteamApiSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fkrzski\\LaravelSteamApiSdk\\SteamServiceProvider"
            ],
            "aliases": {
                "Steam": "Fkrzski\\LaravelSteamApiSdk\\Facades\\Steam"
            }
        }
    },
    "scripts": {
        "lint": [
            "pint --parallel",
            "rector"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:unit": "pest --parallel --coverage --exactly=100",
        "test:mutate": "pest --mutate --parallel --covered-only --min=100",
        "test:types": "phpstan",
        "test:profanity": "pest --profanity",
        "test": [
            "@test:profanity",
            "@test:lint",
            "@test:types",
            "@test:unit",
            "@test:type-coverage",
            "@test:mutate"
        ]
    }
}
